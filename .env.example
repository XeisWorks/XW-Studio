# Database (Railway PostgreSQL)
DATABASE_URL=postgresql://user:pass@host:port/dbname

# Encryption key for API tokens stored in DB
FERNET_MASTER_KEY=

# Fallback: direct API tokens (used if DB unavailable)
SEVDESK_API_TOKEN=
WIX_API_KEY=
WIX_SITE_ID=
WIX_ACCOUNT_ID=
STRIPE_SECRET_KEY=
MOLLIE_ACCESS_TOKEN=
OPENAI_API_KEY=
MS_GRAPH_CLIENT_ID=
MS_GRAPH_TENANT_ID=
MS_GRAPH_MAILBOX=shop@xeisworks.at
FON_TEILNEHMER_ID=
FON_BENUTZER_ID=
FON_PIN=
CLICKUP_API_TOKEN=
GOOGLE_MAPS_API_KEY=

# Microsoft Graph mail delivery for invoice/customer emails
# MSAL device-flow tokens are cached in state/msal_cache.json by default.
# Optional override:
# XW_STUDIO_MSAL_CACHE_PATH=state/msal_cache.json
XW_STUDIO_MSAL_CACHE_PATH=
